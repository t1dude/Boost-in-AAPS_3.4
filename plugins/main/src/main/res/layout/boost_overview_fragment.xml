<?xml version="1.0" encoding="utf-8"?>
<!--
    boost_overview_fragment.xml — Redesigned Boost Overview home screen.
    All colours use theme attributes — no hardcoded dark values.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/boost_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Notifications -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/notifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- ═══ Top section: Pump | BG Bobble | Connection ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp">

                <!-- Pump info column -->
                <LinearLayout
                    android:id="@+id/pump_section"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:focusable="true"
                    android:importantForAccessibility="yes">

                    <TextView
                        android:id="@+id/pump_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PUMP"
                        android:textSize="11sp"
                        android:textColor="?android:attr/textColorTertiary"
                        android:letterSpacing="0.05"
                        android:importantForAccessibility="no"
                        tools:ignore="HardcodedText" />
                    <TextView
                        android:id="@+id/pump_reservoir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorPrimary"
                        android:importantForAccessibility="no"
                        tools:text="87U" />
                    <TextView
                        android:id="@+id/pump_battery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:importantForAccessibility="no"
                        tools:text="🔋 72%" />
                    <TextView
                        android:id="@+id/pump_ages"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="?android:attr/textColorTertiary"
                        android:importantForAccessibility="no"
                        tools:text="🩹 1.4d  📡 4.2d" />
                </LinearLayout>

                <!-- BG Bobble -->
                <app.aaps.plugins.main.general.overview.boost.BgBobbleView
                    android:id="@+id/bg_bobble"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center" />

                <!-- Connection / Loop status column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageView
                        android:id="@+id/connection_icon"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@string/openloop"
                        tools:ignore="ContentDescription" />
                    <TextView
                        android:id="@+id/time_ago"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="4dp"
                        tools:text="2m ago" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═══ Delta row ═══ -->
            <TextView
                android:id="@+id/delta_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingBottom="8dp"
                tools:text="-0.8 mg/dL · Falling slowly" />

            <!-- ═══ Detail panels ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- IOB panel -->
                    <LinearLayout
                        android:id="@+id/panel_iob"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="10dp"
                        android:minHeight="48dp"
                        android:foreground="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IOB"
                            android:textSize="11sp"
                            android:textColor="?android:attr/textColorTertiary"
                            android:letterSpacing="0.1"
                            tools:ignore="HardcodedText" />
                        <TextView
                            android:id="@+id/panel_iob_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="3.21u" />
                    </LinearLayout>

                    <!-- Boost tier panel -->
                    <LinearLayout
                        android:id="@+id/panel_boost"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="10dp"
                        android:minHeight="48dp"
                        android:foreground="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BOOST"
                            android:textSize="11sp"
                            android:textColor="?android:attr/textColorTertiary"
                            android:letterSpacing="0.1"
                            tools:ignore="HardcodedText" />
                        <TextView
                            android:id="@+id/panel_boost_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="Percent Scale" />
                    </LinearLayout>

                    <!-- DynISF panel -->
                    <LinearLayout
                        android:id="@+id/panel_dynisf"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="10dp"
                        android:minHeight="48dp"
                        android:foreground="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DynISF"
                            android:textSize="11sp"
                            android:textColor="?android:attr/textColorTertiary"
                            android:letterSpacing="0.1"
                            tools:ignore="HardcodedText" />
                        <TextView
                            android:id="@+id/panel_dynisf_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="71" />
                    </LinearLayout>

                    <!-- Profile panel -->
                    <LinearLayout
                        android:id="@+id/panel_profile"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="10dp"
                        android:minHeight="48dp"
                        android:foreground="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PROFILE"
                            android:textSize="11sp"
                            android:textColor="?android:attr/textColorTertiary"
                            android:letterSpacing="0.1"
                            tools:ignore="HardcodedText" />
                        <TextView
                            android:id="@+id/panel_profile_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="Default" />
                        <TextView
                            android:id="@+id/panel_profile_pct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="100%" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ Second detail panel row ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:gravity="center_horizontal">

                    <!-- TDD panel -->
                    <LinearLayout
                        android:id="@+id/panel_tdd"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="10dp"
                        android:minHeight="48dp"
                        android:foreground="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TDD"
                            android:textSize="11sp"
                            android:textColor="?android:attr/textColorTertiary"
                            android:letterSpacing="0.1"
                            tools:ignore="HardcodedText" />
                        <TextView
                            android:id="@+id/panel_tdd_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="48.3" />
                    </LinearLayout>

                    <!-- Target panel -->
                    <LinearLayout
                        android:id="@+id/panel_target"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="10dp"
                        android:minHeight="48dp"
                        android:foreground="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TARGET"
                            android:textSize="11sp"
                            android:textColor="?android:attr/textColorTertiary"
                            android:letterSpacing="0.1"
                            tools:ignore="HardcodedText" />
                        <TextView
                            android:id="@+id/panel_target_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="5.5" />
                    </LinearLayout>

                    <!-- Activity / Exercise mode panel -->
                    <LinearLayout
                        android:id="@+id/panel_activity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="10dp"
                        android:minHeight="48dp"
                        android:foreground="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EXERCISE"
                            android:textSize="11sp"
                            android:textColor="?android:attr/textColorTertiary"
                            android:letterSpacing="0.1"
                            tools:ignore="HardcodedText" />
                        <TextView
                            android:id="@+id/panel_activity_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            tools:text="Inactive" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ BG Graph (reuses existing) ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/graphCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_marginTop="4dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- ═══ Primary BG graph ═══ -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.jjoe64.graphview.GraphView
                            android:id="@+id/bg_graph"
                            android:layout_width="match_parent"
                            android:layout_height="260dp"
                            android:contentDescription="@string/a11y_graph" />

                        <Button
                            android:id="@+id/scale_button"
                            android:layout_width="65dp"
                            android:layout_height="35dp"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentTop="true"
                            android:layout_marginStart="35dp"
                            android:contentDescription="@string/a11y_graph_scale"
                            android:drawableEnd="@drawable/ic_arrow_drop_down_white_24dp"
                            android:padding="0dp"
                            android:textAllCaps="false" />

                        <ImageButton
                            android:id="@+id/chart_menu_button"
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="5dp"
                            android:contentDescription="@string/chart_menu"
                            android:paddingTop="5dp"
                            app:srcCompat="@drawable/ic_arrow_drop_down_white_24dp" />

                    </RelativeLayout>

                    <!-- Thin divider between graphs -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="?android:attr/listDivider" />

                    <!-- ═══ IOB graph (time-aligned with BG graph) ═══ -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.jjoe64.graphview.GraphView
                            android:id="@+id/iob_graph"
                            android:layout_width="match_parent"
                            android:layout_height="130dp"
                            android:contentDescription="@string/iob" />

                        <TextView
                            android:id="@+id/iob_graph_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentStart="true"
                            android:layout_marginStart="30dp"
                            android:layout_marginTop="8dp"
                            android:text="IOB"
                            android:textSize="11sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:letterSpacing="0.05"
                            android:importantForAccessibility="no"
                            tools:ignore="HardcodedText" />

                    </RelativeLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Action buttons come from the standard overview_buttons_layout include below -->

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ═══ Pump status bar ═══ -->
    <LinearLayout
        android:id="@+id/pump_status_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">
        <TextView
            android:id="@+id/pump_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="?attr/pumpStatusBackground"
            android:textAppearance="?android:attr/textAppearanceSmall" />
    </LinearLayout>

    <!-- ═══ Progress bar ═══ -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:max="100"
        android:progress="100"
        android:indeterminate="false" />

    <!-- ═══ Action buttons (included from standard layout) ═══ -->
    <include
        android:id="@+id/buttons_layout"
        layout="@layout/overview_buttons_layout" />

</LinearLayout>
